# Copy to .env and fill in the keys you actually use.
# The CLI loads this file on startup and never overrides already-exported vars.

# Required for to-asset naming and process-doc summaries (default models are Anthropic).
ANTHROPIC_API_KEY=

# Required only for `--datalab` PDF conversion.
DATALAB_API_KEY=

# Optional: other providers, usable via the ALEX_*_MODEL overrides below.
OPENAI_API_KEY=
GEMINI_API_KEY=
MISTRAL_API_KEY=

# Optional: Langfuse tracing.
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=

# Optional model overrides. Any LiteLLM model string works, e.g.
# "anthropic/claude-opus-4-8", "openai/gpt-5", "gemini/gemini-2.5-pro".
# ALEX_FAST_SUMMARY_MODEL=
# ALEX_FINAL_SUMMARY_MODEL=
# ALEX_NAMING_MODEL=
